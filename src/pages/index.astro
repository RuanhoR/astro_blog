---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Pagination from '../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_ICON, SITE_TITLE } from '../consts';
import { getTranslation, currentLanguage } from '../i18n';
import BlogList from '../components/BlogList.astro';

const postsPerPage = 5;
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allData = {
	arliceCout: allPosts.length,
	textCout: allPosts.reduce((sum, post) => sum + (post.body?.length || 0), 0)
}
const currentPage = Number(Astro.url.searchParams.get('page')) || 1;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="main">
			<div class="grid">
				<div class="sidenav">
					<div class="grid">
						<img class="image" src={SITE_ICON}></img>
						<div>ruanhor</div>
					</div>
					<div>{getTranslation("AllTextCout") + ": " + allData.textCout}</div>
					<div>{getTranslation("AllAlircleCout") + ": " + allData.arliceCout}</div>
				</div>
				<div class="posts-container">
					<BlogList 
						posts={allPosts}
						layout="card"
						showExcerpt={true}
						postsPerPage={postsPerPage}
						currentPage={currentPage}
					/>
					
					{allPosts.length > postsPerPage && (
						<Pagination 
							currentPage={currentPage} 
							totalPosts={allPosts.length}
							postsPerPage={postsPerPage}
							baseUrl="?page="
						/>
					)}
				</div>
			</div>
		</main>
		<Footer />
		</body>
</html>
<style>
	.posts-container {
		width: 150%;
		margin: 0 auto;
		padding: 2rem;
	}
	
	.image {
		width: 20%;
		height: auto;
		position: relative;
		border-radius: 50%;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
	}
	
	.sidenav {
		border-radius: 12px;
		padding: 2rem;
		margin: 2rem;
		width: 100%;
		box-shadow: var(--card-shadow);
		border: 1px solid var(--card-border);
	}
	.grid {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 60%;
		height: 200%;
		position: relative;
	}
	.main {
		position: relative;
		width: 100%;
	}
</style>