---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Pagination from '../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_ICON, SITE_TITLE } from '../consts';
import BlogList from '../components/BlogList.astro';

const postsPerPage = 5;
const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Calculate word count and reading time at build time
const allData = {
	articleCount: allPosts.length,
	textCount: allPosts.reduce((sum, post) => {
		const content = post.body || '';
		const wordCount = content.replace(/[^\w\s]/g, '').split(/\s+/).filter(word => word.length > 0).length;
		return sum + wordCount;
	}, 0)
}

const allPostsWithReadingTime = allPosts.map(post => {
	const content = post.body || '';
	const wordCount = content.replace(/[^\w\s]/g, '').split(/\s+/).filter(word => word.length > 0).length;
	const readingTime = Math.floor(wordCount / 240); // 240 words per minute
	return {
		...post,
		readingTime
	};
});

const currentPage = Number(Astro.url.searchParams.get('page')) || 1;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="main">
			<div class="grid">
				<div class="sidenav">
					<div class="grid">
						<img class="image" src={SITE_ICON}></img>
						<div>ruanhor</div>
					</div>
					<div id="textCountDisplay"></div>
					<div id="articleCountDisplay"></div>
					<div id="readingTimeDisplay"></div>
				</div>
				<script type="application/json" data-stats>
				{
				  "textCount": ${allData.textCount},
				  "articleCount": ${allData.articleCount}
				}
				</script>
				<div class="posts-container">
				<BlogList 
					posts={allPostsWithReadingTime}
					layout="card"
					showExcerpt={true}
					postsPerPage={postsPerPage}
					currentPage={currentPage}
				/>
					
					{allPosts.length > postsPerPage && (
						<Pagination 
							currentPage={currentPage} 
							totalPosts={allPosts.length}
							postsPerPage={postsPerPage}
							baseUrl="?page="
						/>
					)}
				</div>
			</div>
		</main>
		<Footer />
		<script>
		// 动态更新统计信息的函数
		function updateStatistics() {
			const textCountElem = document.getElementById('textCountDisplay');
			const articleCountElem = document.getElementById('articleCountDisplay');
			const readingTimeElem = document.getElementById('readingTimeDisplay');
			
			if (!textCountElem || !articleCountElem || !readingTimeElem) return;
			
			// 检测当前语言
			const getCurrentLanguage = () => {
				const browserLang = navigator.language || navigator.languages[0] || 'zh';
				return browserLang.startsWith('zh') ? 'zh' : 'en';
			};
			
			const lang = getCurrentLanguage();
			const translations = {
				textCount: { zh: '总字数', en: 'Total text count' },
				articleCount: { zh: '总文章数', en: 'Total articles' },
				averageReadingTime: { zh: '平均阅读时间', en: 'Average reading time' }
			};
			
			// 从data属性获取统计信息
			const dataScript = document.querySelector('script[type="application/json"][data-stats]');
			if (dataScript) {
				try {
					const data = JSON.parse(dataScript.textContent);
					const averageReadingTime = Math.floor(data.textCount / data.articleCount / 240);
					const textCountData = `${translations.textCount[lang]}: ${data.textCount.toLocaleString()}`;
					const articleCountData = `${translations.articleCount[lang]}: ${data.articleCount}`;
					const readingTimeData = `${translations.averageReadingTime[lang]}: ${averageReadingTime} ${lang === 'zh' ? '分钟' : 'minutes'}`;
					
					textCountElem.textContent = textCountData;
					articleCountElem.textContent = articleCountData;
					readingTimeElem.textContent = readingTimeData;
				} catch (error) {
					console.error('Failed to parse statistics data:', error);
				}
			}
		}
		
		// 页面加载时更新
		document.addEventListener('DOMContentLoaded', updateStatistics);
		
		// 监听语言切换事件
		window.addEventListener('languagechange', updateStatistics);
		</script>
		</body>
</html>
<style>
	.posts-container {
		width: 150%;
		margin: 0 auto;
		padding: 2rem;
	}
	
	.image {
		width: 20%;
		height: auto;
		position: relative;
		border-radius: 50%;
		box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
	}
	
	.sidenav {
		border-radius: 12px;
		padding: 2rem;
		margin: 2rem;
		width: 100%;
		box-shadow: var(--card-shadow);
		border: 1px solid var(--card-border);
	}
	.grid {
		display: flex;
		align-items: center;
		justify-content: space-between;
		width: 60%;
		height: 200%;
		position: relative;
	}
	.main {
		position: relative;
		width: 100%;
	}
</style>