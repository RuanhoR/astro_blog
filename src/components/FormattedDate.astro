---
import dayjs from 'dayjs';
import 'dayjs/locale/zh';
import 'dayjs/locale/en';

interface Props {
	date: Date;
	locale?: string;
}

const { date, locale = 'en' } = Astro.props;

// 设置dayjs语言环境
dayjs.locale(locale);
---

<time datetime={date.toISOString()}>
	{dayjs(date).format('MMMM DD, YYYY')}
</time>
