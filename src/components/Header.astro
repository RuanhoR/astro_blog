---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import Search from "./Search.vue"
import MobileSearch from "./MobileSearch.vue"
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<a href="/" data-link="home">Home</a>
			<a href="/blog" data-link="blog">Blog</a>
			<a href="/about" data-link="about">About</a>
		</div>
		<div class="social-links">
			<div class="search-container">
				<Search client:load posts={await getCollection("blog")}/>
			</div>
		</div>
		<div class="mobile-search-container">
				<MobileSearch client:load posts={await getCollection("blog")}/>
		</div>
	</nav>
</header>
<script>
// 动态更新链接文本的函数
function updateLinkText() {
  const links = document.querySelectorAll('.internal-links a');
  const translations = {
    home: { zh: '首页', en: 'Home' },
    blog: { zh: '博客', en: 'Blog' },
    about: { zh: '关于', en: 'About' }
  };
  
  // 检测当前语言
  const getCurrentLanguage = () => {
    const browserLang = navigator.language || navigator.languages[0] || 'zh';
    return browserLang.startsWith('zh') ? 'zh' : 'en';
  };
  
  const lang = getCurrentLanguage();
  
  links.forEach(link => {
    const linkType = link.getAttribute('data-link');
    // 使用类型安全的访问方式
    if (linkType && (linkType === 'home' || linkType === 'blog' || linkType === 'about')) {
      link.textContent = translations[linkType][lang];
    }
  });
}

// 页面加载时更新
document.addEventListener('DOMContentLoaded', updateLinkText);

// 监听可能的语言切换事件
window.addEventListener('languagechange', updateLinkText);
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: transparent;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	header * {
		color: var(--font-color-white)
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		align-items: center;
	}
	.search-container {
		position: relative;
	}
	.search-btn {
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 6px;
		padding: 0.5rem 0.75rem;
		color: var(--font-color-white);
		cursor: pointer;
		font-size: 1rem;
		opacity: 0.8;
		transition: all 0.2s ease;
		pointer-events: auto;
		position: relative;
		z-index: 1;
	}
	.search-btn:hover {
		opacity: 1;
		background: var(--card-hover-bg);
	}
	.mobile-search-container {
		display: none;
	}

	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
		.mobile-search-container {
			display: block;
		}
		.internal-links {
			flex: 1;
			justify-content: center;
			margin: 0 10px;
		}
		.internal-links a {
			margin: 0 5px;
			font-size: 0.9rem;
		}
		h2 {
			font-size: 0.9rem;
			min-width: 80px;
		}
	}
</style>
