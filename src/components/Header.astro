---
import { getCollection } from 'astro:content';
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import Search from "./Search.vue"
import { currentLanguage, getTranslation } from '../i18n/index';
---

<header>
	<nav>
		<h2><a href="/">{SITE_TITLE}</a></h2>
		<div class="internal-links">
			<HeaderLink href="/">{getTranslation("Home", currentLanguage)}</HeaderLink>
			<HeaderLink href="/blog">{getTranslation("Blog", currentLanguage)}</HeaderLink>
			<HeaderLink href="/about">{getTranslation("About", currentLanguage)}</HeaderLink>
		</div>
		<div class="social-links">
			<div class="search-container">
				<Search client:load posts={await getCollection("blog")}/>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background-color: transparent;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}
	header * {
		color: var(--font-color-white)
	}
	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links {
		display: flex;
		align-items: center;
	}
	.search-container {
		position: relative;
	}
	.search-btn {
		background: var(--card-bg);
		border: 1px solid var(--card-border);
		border-radius: 6px;
		padding: 0.5rem 0.75rem;
		color: var(--font-color-white);
		cursor: pointer;
		font-size: 1rem;
		opacity: 0.8;
		transition: all 0.2s ease;
		pointer-events: auto;
		position: relative;
		z-index: 1;
	}
	.search-btn:hover {
		opacity: 1;
		background: var(--card-hover-bg);
	}
	@media (max-width: 720px) {
		.social-links {
			display: none;
		}
	}
</style>
