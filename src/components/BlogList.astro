---
import FormattedDate from './FormattedDate.astro';
import { getCurrentLanguage } from '../i18n';
import type { getCollection } from 'astro:content';
import GoImage from "./../assets/go.svg"
export interface Props {
  posts: Array<Awaited<ReturnType<typeof getCollection>>[0] & { readingTime?: number }>;
  layout?: 'card' | 'grid';
  showExcerpt?: boolean;
  postsPerPage?: number;
  currentPage?: number;
}
// 构建时设置默认语言，运行时通过客户端脚本更新
const defaultLanguage = 'zh';
const { 
  posts, 
  layout = 'card', 
  showExcerpt = true, 
  postsPerPage,
  currentPage = 1 
} = Astro.props;

let displayPosts = posts;
if (postsPerPage) {
  const startIndex = (currentPage - 1) * postsPerPage;
  displayPosts = posts.slice(startIndex, startIndex + postsPerPage);
}
---

<!-- Cards layout (used in main index) -->
{layout === 'card' && displayPosts.map((post) => (
  <a href={"/blog/" + post.id} class="blog-card" title="Read full article">
    <div class="blog-content">
      <div class="blog-text">
        <div class="blog-header">
          <div class="blog-title">{post.data.title}</div>
        </div>
        {post.data.pubDate && (
          <div class="blog-date">
            <FormattedDate date={post.data.pubDate} locale="zh" />
            {post.readingTime && post.readingTime > 0 && (
              <span class="reading-time" data-reading-time="{post.readingTime}"> • {post.readingTime} 分钟读出</span>
            )}
          </div>
        )}
        {showExcerpt && (
          <div class="blog-excerpt">
            {post.body ? post.body.slice(0, 120) + '...' : "No content available"}
          </div>
        )}
      </div>
      <div class="blog-image">
        {post.data.heroImage ? (
          <img src={post.data.heroImage.src} alt={post.data.title} class="cover-image" />
        ) : (
          <GoImage></GoImage>
        )}
      </div>
    </div>
  </a>
))}

<!-- Grid layout (used in blog index) -->
{layout === 'grid' && (
  <ul>
    {displayPosts.map((post, index) => (
      <li class={index === 0 ? 'first-post' : ''}>
        <a href={`/blog/${post.id}/`}>
          {post.data.heroImage && (
            <img src={post.data.heroImage.src} alt={post.data.title} />
          )}
          <h4 class="title">{post.data.title}</h4>
          <p class="date">
            <FormattedDate date={post.data.pubDate} />
          </p>
        </a>
      </li>
    ))}
  </ul>
)}

<style>
.blog-card {
  border-radius: 16px;
  padding: 1.5rem;
  margin-bottom: 1.5rem;
  box-shadow: var(--card-shadow);
  transition: all 0.3s ease;
  display: block;
  text-decoration: none;
  border-left: 4px solid var(--font-color-blue);
  background-color: var(--card-bg);
  border: 1px solid var(--card-border);
}

.blog-card:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
  background-color: var(--card-hover-bg, var(--card-bg));
}

.blog-content {
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
}

.blog-text {
  flex: 1;
}

.blog-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 0.75rem;
}

.blog-title {
  font-size: 1.3rem;
  font-weight: 600;
  margin: 0;
  line-height: 1.3;
  flex: 1;
  margin-right: 1rem;
  color: var(--font-color-white);
}

.blog-date {
  font-size: 0.85rem;
  color: #718096;
  margin-bottom: 0.75rem;
}

.blog-excerpt {
  color: #718096;
  font-size: 0.95rem;
  line-height: 1.5;
}

.blog-image {
  flex-shrink: 0;
  width: 120px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.blog-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--card-border);
  font-size: 2rem;
}

/* Grid styles for blog index */
ul {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
  list-style-type: none;
  margin: 0;
  padding: 0;
}

ul li {
  width: calc(50% - 1rem);
}

ul li * {
  text-decoration: none;
  transition: 0.2s ease;
}

ul li.first-child {
  width: 100%;
  margin-bottom: 0;
  text-align: center;
}

ul li.first-child img {
  width: 100%;
}

ul li.first-child .title {
  font-size: 2.369rem;
}

ul li img {
  margin-bottom: 0.5rem;
  border-radius: 12px;
}

ul li a {
  display: block;
}

.title {
  margin: 0;
  color: var(--font-color-white);
  line-height: 1;
}

.date {
  margin: 0;
  color: #718096;
}

ul li a:hover h4,
ul li a:hover .date {
  color: var(--accent);
}

ul a:hover img {
  box-shadow: var(--box-shadow);
}

@media (max-width: 720px) {
  ul {
    gap: 0.5em;
  }
  
  ul li {
    width: 100%;
    text-align: center;
  }
  
  ul li.first-post {
    margin-bottom: 0;
  }
  
  ul li.first-post .title {
    font-size: 1.563em;
  }
  
  .blog-content {
    flex-direction: column;
  }
  
  .blog-image {
    width: 100%;
    height: 200px;
  }
}
</style>
</style>